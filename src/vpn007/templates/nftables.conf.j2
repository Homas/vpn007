{# Template: nftables.conf — nftables firewall rules with default-deny and AS/subnet blocking #}
{# © Vadim Pavlov 2026 #}
#!/usr/sbin/nft -f

# Flush only VPN007-managed tables (preserve Docker's iptables-nft chains)
table inet filter
delete table inet filter
{% if outgoing_ip %}
table ip nat
delete table ip nat
{% endif %}

table inet filter {
    set blocked_v4 {
        type ipv4_addr
        flags interval
{% if blocked_v4_prefixes %}
        elements = {
{% for prefix in blocked_v4_prefixes %}
            {{ prefix }}{{ "," if not loop.last }}
{% endfor %}
        }
{% endif %}
    }

    set blocked_v6 {
        type ipv6_addr
        flags interval
{% if blocked_v6_prefixes %}
        elements = {
{% for prefix in blocked_v6_prefixes %}
            {{ prefix }}{{ "," if not loop.last }}
{% endfor %}
        }
{% endif %}
    }

    set approved_ssh_v4 {
        type ipv4_addr
        flags interval
{% if ssh_approved_ips %}
        elements = {
{% for ip in ssh_approved_ips %}
            {{ ip }}{{ "," if not loop.last }}
{% endfor %}
        }
{% endif %}
    }

    chain input {
        type filter hook input priority 0; policy drop;

        # Allow established/related connections
        ct state established,related accept

        # Allow loopback
        iif lo accept

        # Block traffic from blocked AS/subnet sources
        ip saddr @blocked_v4 drop
        ip6 saddr @blocked_v6 drop

{% if ssh_approved_ips or ssh_approved_hostnames %}
        # Allow SSH from approved IPs only (static + resolved hostnames)
        ip saddr @approved_ssh_v4 tcp dport 22 accept
{% else %}
        # Allow SSH from any source (no SSH_APPROVED_IPS or SSH_APPROVED_HOSTNAMES configured)
        tcp dport 22 accept
{% endif %}

        # Allow HTTPS on port {{ https_port }}
        tcp dport {{ https_port }} accept

{% if enable_port_8443 %}
        # Allow optional secondary HTTPS port
        tcp dport 8443 accept

{% endif %}
        # Allow AmneziaWG panel HTTPS port
        tcp dport {{ awg_panel_https_port }} accept

        # Allow AmneziaWG UDP port
        udp dport {{ awg_listen_port }} accept

        # Port 80 is NOT in the base ruleset. It is opened dynamically:
        # - During initial certificate acquisition by the deployer
        # - During certbot renewal by the certbot-renew.sh pre/post-hook
        # This minimizes DPI fingerprinting surface.

        # Allow ICMP for connectivity diagnostics
        ip protocol icmp accept
        ip6 nexthdr icmpv6 accept
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        # Allow established/related forwarded connections
        ct state established,related accept

        # Allow Docker bridge containers to reach the internet
        ip saddr 172.20.0.0/16 accept
        # Allow return traffic to Docker bridge containers
        ip daddr 172.20.0.0/16 ct state established,related accept

        # Allow AmneziaWG VPN clients to reach the internet
        ip saddr 10.8.0.0/24 accept
        ip6 saddr fdcc:ad94:bacf:61a4::cafe:0/112 accept
    }

    chain output {
        type filter hook output priority 0; policy accept;

        # Block outbound traffic to blocked AS/subnets
        ip daddr @blocked_v4 drop
        ip6 daddr @blocked_v6 drop
    }
}

{% if outgoing_ip %}
table ip nat {
    chain postrouting {
        type nat hook postrouting priority 100;

        # Multi-IP: SNAT VPN client traffic to use designated egress IP.
        # Only applies to traffic from Docker bridge and AmneziaWG subnets,
        # NOT to the server's own outbound connections (which use the default route).
        ip saddr 172.20.0.0/16 oifname != "lo" snat to {{ outgoing_ip }}
        ip saddr 10.8.0.0/24 oifname != "lo" snat to {{ outgoing_ip }}
    }
}
{% endif %}
