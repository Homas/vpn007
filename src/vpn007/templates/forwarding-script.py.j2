"""Standalone forwarding installer for a secondary VM.

This script is generated by VPN007 and should be executed on the secondary VM.
It installs the tunnel endpoint, configures nftables DNAT/SNAT rules for each
port forward, and implements reconnection with exponential backoff.
"""
from __future__ import annotations

import logging
import os
import shutil
import subprocess
import sys
import time

# ---------------------------------------------------------------------------
# Embedded configuration (generated by VPN007)
# ---------------------------------------------------------------------------

PRIMARY_VM_IP: str = "{{ primary_vm_ip }}"
EXIT_NODE_HOST: str = "{{ exit_node_host }}"
TUNNEL_TYPE: str = "{{ tunnel_type }}"
REVERSE_INITIATED: bool = {{ "True" if reverse_initiated else "False" }}
FORWARDING_MODE: str = "{{ forwarding_mode }}"

FORWARDING_PORTS: list[dict[str, str | int]] = [
{% for pf in forwarding_ports %}
    {"protocol": "{{ pf.protocol }}", "listen_port": {{ pf.listen_port }}, "forward_port": {{ pf.forward_port }}, "description": "{{ pf.description }}"},
{% endfor %}
]

RECONNECT_INITIAL_DELAY: int = {{ reconnect_initial_delay_sec }}
RECONNECT_MAX_DELAY: int = {{ reconnect_max_delay_sec }}

# WireGuard/AmneziaWG tunnel subnet (point-to-point)
WG_TUNNEL_SUBNET: str = "{{ tunnel_subnet }}"
WG_LOCAL_IP: str = "{{ tunnel_secondary_ip }}"   # Secondary VM side
WG_REMOTE_IP: str = "{{ tunnel_primary_ip }}"  # Primary VM side
WG_LISTEN_PORT: int = 51821

# SSH tunnel settings
SSH_PORT: int = 22
AUTOSSH_MONITOR_PORT: int = 20000
SSH_TUNNEL_USER: str = "vpn007-tunnel"

# Xray VLESS+Reality tunnel settings
XRAY_TUNNEL_UUID: str = "{{ xray_tunnel_uuid }}"
XRAY_TUNNEL_PRIVATE_KEY: str = "{{ xray_tunnel_private_key }}"
XRAY_TUNNEL_PUBLIC_KEY: str = "{{ xray_tunnel_public_key }}"
XRAY_TUNNEL_SHORT_ID: str = "{{ xray_tunnel_short_id }}"
XRAY_TUNNEL_SNI: str = "{{ xray_tunnel_sni }}"
XRAY_TUNNEL_PORT: int = {{ xray_tunnel_port }}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)
log = logging.getLogger("vpn007-forwarding")


# ---------------------------------------------------------------------------
# Utility helpers
# ---------------------------------------------------------------------------

def run_cmd(
    cmd: list[str],
    check: bool = True,
    capture: bool = False,
) -> subprocess.CompletedProcess[str]:
    """Run a shell command with logging."""
    log.debug("Running: %s", " ".join(cmd))
    return subprocess.run(
        cmd,
        check=check,
        capture_output=capture,
        text=True,
    )


def command_exists(name: str) -> bool:
    """Check whether a command is available on PATH."""
    return shutil.which(name) is not None


def detect_package_manager() -> str:
    """Detect the system package manager."""
    if command_exists("apt-get"):
        return "apt"
    if command_exists("apk"):
        return "apk"
    if command_exists("dnf"):
        return "dnf"
    if command_exists("yum"):
        return "yum"
    return "unknown"


def install_packages(packages: list[str]) -> None:
    """Install packages using the detected package manager."""
    pm = detect_package_manager()
    match pm:
        case "apt":
            run_cmd(["apt-get", "update", "-qq"])
            run_cmd(["apt-get", "install", "-y", "-qq"] + packages)
        case "apk":
            run_cmd(["apk", "add", "--no-cache"] + packages)
        case "dnf":
            run_cmd(["dnf", "install", "-y"] + packages)
        case "yum":
            run_cmd(["yum", "install", "-y"] + packages)
        case _:
            log.error("Unsupported package manager. Install manually: %s", packages)
            sys.exit(1)


# ---------------------------------------------------------------------------
# Tunnel installation
# ---------------------------------------------------------------------------

def install_wireguard() -> None:
    """Install WireGuard (or AmneziaWG) tools and kernel module."""
    log.info("Installing WireGuard/AmneziaWG tunnel endpoint...")
    if not command_exists("wg"):
        pm = detect_package_manager()
        match pm:
            case "apt":
                install_packages(["wireguard", "wireguard-tools"])
            case "apk":
                install_packages(["wireguard-tools"])
            case _:
                install_packages(["wireguard-tools"])
    else:
        log.info("WireGuard tools already installed.")


def install_ssh_tunnel() -> None:
    """Install autossh for persistent SSH tunnels."""
    log.info("Installing SSH tunnel endpoint (autossh)...")
    if not command_exists("autossh"):
        install_packages(["autossh"])
    else:
        log.info("autossh already installed.")
    if not command_exists("ssh"):
        install_packages(["openssh-client"])


def install_tailscale() -> None:
    """Install Tailscale client."""
    log.info("Installing Tailscale tunnel endpoint...")
    if not command_exists("tailscale"):
        try:
            run_cmd(["curl", "-fsSL", "https://tailscale.com/install.sh", "-o", "/tmp/tailscale-install.sh"])
            run_cmd(["sh", "/tmp/tailscale-install.sh"])
        except subprocess.CalledProcessError:
            log.error("Failed to install Tailscale via install script.")
            sys.exit(1)
    else:
        log.info("Tailscale already installed.")


def install_xray() -> None:
    """Install Xray binary for VLESS+Reality tunnel."""
    log.info("Installing Xray for VLESS+Reality tunnel...")
    xray_path = "/usr/local/bin/xray"
    if os.path.exists(xray_path):
        log.info("Xray already installed at %s.", xray_path)
        return
    try:
        # Download the official Xray install script
        run_cmd(["curl", "-fsSL", "https://github.com/XTLS/Xray-install/raw/main/install-release.sh", "-o", "/tmp/xray-install.sh"])
        run_cmd(["bash", "/tmp/xray-install.sh", "install"])
    except subprocess.CalledProcessError:
        log.error("Failed to install Xray. Install manually: https://github.com/XTLS/Xray-core/releases")
        sys.exit(1)
    if not os.path.exists(xray_path) and not os.path.exists("/usr/bin/xray"):
        log.error("Xray binary not found after installation.")
        sys.exit(1)
    log.info("Xray installed successfully.")


def install_tunnel_endpoint() -> None:
    """Install the tunnel endpoint based on the configured tunnel type."""
    match TUNNEL_TYPE:
        case "wireguard":
            install_wireguard()
        case "ssh":
            install_ssh_tunnel()
        case "tailscale":
            install_tailscale()
        case "xray":
            install_xray()
        case _:
            log.error("Unknown tunnel type: %s", TUNNEL_TYPE)
            sys.exit(1)


# ---------------------------------------------------------------------------
# Tunnel setup
# ---------------------------------------------------------------------------

def setup_wireguard_tunnel() -> None:
    """Configure a WireGuard point-to-point tunnel to the primary VM."""
    log.info("Configuring WireGuard tunnel to %s...", PRIMARY_VM_IP)

    conf_path = "/etc/wireguard/wg-tunnel.conf"
    os.makedirs("/etc/wireguard", exist_ok=True)

    # Generate keys if not already present
    if not os.path.exists("/etc/wireguard/tunnel_private.key"):
        result = run_cmd(["wg", "genkey"], capture=True)
        private_key = result.stdout.strip()
        with open("/etc/wireguard/tunnel_private.key", "w") as f:
            f.write(private_key)
        os.chmod("/etc/wireguard/tunnel_private.key", 0o600)

        result = run_cmd(
            ["wg", "pubkey"],
            capture=True,
        )
        # We need to pipe the private key — use a different approach
        pub_result = subprocess.run(
            ["wg", "pubkey"],
            input=private_key,
            capture_output=True,
            text=True,
            check=True,
        )
        public_key = pub_result.stdout.strip()
        with open("/etc/wireguard/tunnel_public.key", "w") as f:
            f.write(public_key)
        log.info("Generated WireGuard keys. Public key: %s", public_key)
        log.info("Add this public key as a peer on the primary VM.")
    else:
        with open("/etc/wireguard/tunnel_private.key") as f:
            private_key = f.read().strip()

    if REVERSE_INITIATED:
        # Secondary VM connects to primary VM
        endpoint_line = f"Endpoint = {PRIMARY_VM_IP}:{WG_LISTEN_PORT}"
    else:
        # Primary VM connects to secondary VM — no endpoint needed here
        endpoint_line = f"# Primary VM will connect to us on port {WG_LISTEN_PORT}"

    conf_content = f"""[Interface]
PrivateKey = {private_key}
Address = {WG_LOCAL_IP}/30
ListenPort = {WG_LISTEN_PORT}

[Peer]
# Primary VM public key — replace with actual key
PublicKey = REPLACE_WITH_PRIMARY_VM_PUBLIC_KEY
AllowedIPs = {WG_REMOTE_IP}/32
{endpoint_line}
PersistentKeepalive = 25
"""
    with open(conf_path, "w") as f:
        f.write(conf_content)
    os.chmod(conf_path, 0o600)

    # Bring up the interface
    run_cmd(["wg-quick", "down", "wg-tunnel"], check=False)
    run_cmd(["wg-quick", "up", "wg-tunnel"])
    log.info("WireGuard tunnel interface wg-tunnel is up.")


def ensure_tunnel_user_exists_on_remote() -> None:
    """Create the unprivileged tunnel user on the remote (primary) VM.

    The SSH tunnel connects as an unprivileged user (vpn007-tunnel) on the
    remote side. This user has no shell, no password, and no home directory
    beyond ~/.ssh. It can only hold the SSH connection open — it cannot
    execute commands or escalate privileges.

    This function is a no-op if the user already exists on the remote.
    It prints instructions for the operator to create the user manually
    if SSH access to the remote is not available from here.
    """
    log.info(
        "The SSH tunnel uses unprivileged user '%s' on the remote VM (%s).",
        SSH_TUNNEL_USER,
        PRIMARY_VM_IP,
    )
    log.info(
        "Ensure this user exists on the remote VM. Create it with:"
    )
    log.info(
        "  ssh root@%s 'useradd -r -s /usr/sbin/nologin -d /home/%s -m %s'",
        PRIMARY_VM_IP,
        SSH_TUNNEL_USER,
        SSH_TUNNEL_USER,
    )
    log.info(
        "  ssh root@%s 'mkdir -p /home/%s/.ssh && chmod 700 /home/%s/.ssh && "
        "chown %s:%s /home/%s/.ssh'",
        PRIMARY_VM_IP,
        SSH_TUNNEL_USER,
        SSH_TUNNEL_USER,
        SSH_TUNNEL_USER,
        SSH_TUNNEL_USER,
        SSH_TUNNEL_USER,
    )


def setup_ssh_tunnel() -> None:
    """Configure an SSH tunnel to/from the primary VM using autossh.

    The tunnel connects as the unprivileged user 'vpn007-tunnel' on the
    remote side. This user has /usr/sbin/nologin as its shell and cannot
    execute commands — it only holds the SSH connection for port forwarding.
    """
    log.info("Configuring SSH tunnel to %s...", PRIMARY_VM_IP)

    if REVERSE_INITIATED:
        # Secondary VM initiates reverse SSH tunnel to primary VM.
        # Each forwarding port gets a remote forward.
        ensure_tunnel_user_exists_on_remote()
        forwards: list[str] = []
        for pf in FORWARDING_PORTS:
            proto = pf["protocol"]
            listen_port = pf["listen_port"]
            forward_port = pf["forward_port"]
            if proto == "tcp":
                forwards.extend(["-R", f"{listen_port}:127.0.0.1:{forward_port}"])
        log.info(
            "Starting reverse SSH tunnel with %d TCP forwards...",
            len(forwards) // 2,
        )
        cmd = [
            "autossh",
            "-M", str(AUTOSSH_MONITOR_PORT),
            "-N",
            "-o", "ServerAliveInterval=30",
            "-o", "ServerAliveCountMax=3",
            "-o", "StrictHostKeyChecking=accept-new",
            "-p", str(SSH_PORT),
        ] + forwards + [f"{SSH_TUNNEL_USER}@{PRIMARY_VM_IP}"]
        log.info("autossh command: %s", " ".join(cmd))
        # autossh runs in the foreground — it handles reconnection itself
        subprocess.Popen(cmd)
    else:
        # Primary VM initiates — secondary just needs sshd running
        # and the vpn007-tunnel user created for the incoming connection.
        log.info("SSH tunnel mode: primary VM will connect to us.")
        log.info("Ensure sshd is running and accessible on port %d.", SSH_PORT)
        log.info(
            "Creating local tunnel user '%s' for incoming connections...",
            SSH_TUNNEL_USER,
        )
        # Create the unprivileged user on this (secondary) VM
        result = run_cmd(
            ["id", SSH_TUNNEL_USER], check=False, capture=True
        )
        if result.returncode != 0:
            run_cmd([
                "useradd", "-r",
                "-s", "/usr/sbin/nologin",
                "-d", f"/home/{SSH_TUNNEL_USER}",
                "-m",
                SSH_TUNNEL_USER,
            ])
            log.info("Created user '%s'.", SSH_TUNNEL_USER)
        else:
            log.info("User '%s' already exists.", SSH_TUNNEL_USER)

        # Set up .ssh directory for the tunnel user
        ssh_dir = f"/home/{SSH_TUNNEL_USER}/.ssh"
        os.makedirs(ssh_dir, exist_ok=True)
        os.chmod(ssh_dir, 0o700)
        run_cmd(["chown", "-R", f"{SSH_TUNNEL_USER}:{SSH_TUNNEL_USER}", ssh_dir])
        log.info(
            "Install the primary VM's public key in %s/authorized_keys",
            ssh_dir,
        )


def setup_tailscale_tunnel() -> None:
    """Configure Tailscale for inter-VM forwarding."""
    log.info("Configuring Tailscale tunnel...")
    # Ensure tailscale is up
    result = run_cmd(["tailscale", "status"], check=False, capture=True)
    if result.returncode != 0:
        log.info("Tailscale not connected. Running 'tailscale up'...")
        run_cmd(["tailscale", "up"])
    else:
        log.info("Tailscale is already connected.")

    # Enable IP forwarding for Tailscale
    run_cmd(["sysctl", "-w", "net.ipv4.ip_forward=1"])
    log.info("Tailscale tunnel configured. Ensure both VMs are on the same tailnet.")


def setup_xray_tunnel() -> None:
    """Configure Xray VLESS+Reality tunnel.

    This VM acts as the Xray server (exit node) — it receives VLESS+Reality
    connections from the primary VM and routes traffic to the internet.

    For a lightweight exit node: Xray listens directly on XRAY_TUNNEL_PORT.
    For a full VPN007 node: the primary VM connects as a regular VLESS client
    to the existing 3x-ui Xray instance (this function generates the standalone
    Xray server config for the lightweight case).
    """
    log.info("Configuring Xray VLESS+Reality tunnel (server mode)...")

    xray_config_dir = "/etc/xray"
    os.makedirs(xray_config_dir, exist_ok=True)

    # Generate Xray server config for the tunnel
    xray_config = {
        "log": {"loglevel": "warning"},
        "inbounds": [
            {
                "tag": "vless-reality-tunnel",
                "listen": "0.0.0.0",
                "port": XRAY_TUNNEL_PORT,
                "protocol": "vless",
                "settings": {
                    "clients": [
                        {
                            "id": XRAY_TUNNEL_UUID,
                            "flow": "xtls-rprx-vision",
                        }
                    ],
                    "decryption": "none",
                },
                "streamSettings": {
                    "network": "tcp",
                    "security": "reality",
                    "realitySettings": {
                        "show": False,
                        "dest": f"{XRAY_TUNNEL_SNI}:443",
                        "xver": 0,
                        "serverNames": [XRAY_TUNNEL_SNI],
                        "privateKey": XRAY_TUNNEL_PRIVATE_KEY,
                        "shortIds": [XRAY_TUNNEL_SHORT_ID],
                    },
                },
            }
        ],
        "outbounds": [
            {
                "tag": "direct",
                "protocol": "freedom",
                "settings": {},
            }
        ],
    }

    import json
    config_path = f"{xray_config_dir}/config.json"
    with open(config_path, "w") as f:
        json.dump(xray_config, f, indent=2)
    os.chmod(config_path, 0o600)
    log.info("Xray config written to %s.", config_path)

    # Create systemd service for Xray tunnel
    xray_bin = "/usr/local/bin/xray"
    if not os.path.exists(xray_bin):
        xray_bin = "/usr/bin/xray"

    service_content = f"""[Unit]
Description=VPN007 Xray VLESS+Reality Tunnel (exit node)
Documentation=https://github.com/Homas/vpn007
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart={xray_bin} run -config {config_path}
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
"""
    service_path = "/etc/systemd/system/vpn007-xray-tunnel.service"
    with open(service_path, "w") as f:
        f.write(service_content)

    # Enable IP forwarding
    run_cmd(["sysctl", "-w", "net.ipv4.ip_forward=1"])

    # Start the service
    run_cmd(["systemctl", "daemon-reload"])
    run_cmd(["systemctl", "enable", "--now", "vpn007-xray-tunnel.service"])
    log.info("Xray tunnel service started (listening on port %d).", XRAY_TUNNEL_PORT)
    log.info("Primary VM should connect with:")
    log.info("  UUID: %s", XRAY_TUNNEL_UUID)
    log.info("  SNI: %s", XRAY_TUNNEL_SNI)
    log.info("  Public key: %s", XRAY_TUNNEL_PUBLIC_KEY)
    log.info("  Short ID: %s", XRAY_TUNNEL_SHORT_ID)


def setup_tunnel() -> None:
    """Set up the encrypted tunnel based on the configured type."""
    match TUNNEL_TYPE:
        case "wireguard":
            setup_wireguard_tunnel()
        case "ssh":
            setup_ssh_tunnel()
        case "tailscale":
            setup_tailscale_tunnel()
        case "xray":
            setup_xray_tunnel()
        case _:
            log.error("Unknown tunnel type: %s", TUNNEL_TYPE)
            sys.exit(1)


# ---------------------------------------------------------------------------
# nftables DNAT/SNAT rules
# ---------------------------------------------------------------------------

def get_tunnel_peer_ip() -> str:
    """Return the tunnel peer IP (primary VM side) for DNAT/SNAT rules."""
    match TUNNEL_TYPE:
        case "wireguard":
            return WG_REMOTE_IP
        case "ssh":
            # SSH tunnel forwards are handled by autossh port forwarding,
            # but we still set up nftables for non-SSH forwarded traffic.
            return PRIMARY_VM_IP
        case "tailscale":
            # Use the primary VM's Tailscale IP — operator should replace
            return PRIMARY_VM_IP
        case "xray":
            # Xray is a proxy, not a routed tunnel. For 'ports' mode,
            # traffic is proxied through Xray (no DNAT needed on this VM).
            # For 'all' mode, Xray uses tproxy. Return primary VM IP
            # as a reference for nftables rules.
            return PRIMARY_VM_IP
        case _:
            return PRIMARY_VM_IP


def configure_nftables_forwarding() -> None:
    """Configure nftables DNAT/SNAT rules for forwarding.

    In 'ports' mode: creates per-port DNAT rules for each FORWARDING_PORTS entry.
    In 'all' mode: routes all traffic through the tunnel using policy-based routing.
    """
    log.info("Configuring nftables forwarding rules (mode=%s)...", FORWARDING_MODE)

    # Enable IP forwarding
    run_cmd(["sysctl", "-w", "net.ipv4.ip_forward=1"])

    tunnel_peer_ip = get_tunnel_peer_ip()

    if FORWARDING_MODE == "all":
        _configure_nftables_all_traffic(tunnel_peer_ip)
    else:
        _configure_nftables_port_forwarding(tunnel_peer_ip)


def _configure_nftables_port_forwarding(tunnel_peer_ip: str) -> None:
    """Configure per-port DNAT/SNAT forwarding rules."""
    # Build the nftables ruleset
    rules = """#!/usr/sbin/nft -f
# VPN007 forwarding rules (mode: ports) — generated by VPN007
# Do not edit manually; re-run the forwarding script to regenerate.

table ip vpn007_forward {
    chain prerouting {
        type nat hook prerouting priority -100; policy accept;
"""

    for pf in FORWARDING_PORTS:
        proto = pf["protocol"]
        listen_port = pf["listen_port"]
        forward_port = pf["forward_port"]
        desc = pf.get("description", "")
        comment = f"  # {desc}" if desc else ""
        rules += f"        {proto} dport {listen_port} dnat to {tunnel_peer_ip}:{forward_port}{comment}\n"

    rules += """    }

    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
"""

    for pf in FORWARDING_PORTS:
        proto = pf["protocol"]
        forward_port = pf["forward_port"]
        rules += f"        {proto} dport {forward_port} masquerade\n"

    rules += """    }

    chain forward {
        type filter hook forward priority 0; policy drop;
        ct state established,related accept
"""

    for pf in FORWARDING_PORTS:
        proto = pf["protocol"]
        forward_port = pf["forward_port"]
        rules += f"        {proto} dport {forward_port} accept\n"

    rules += """    }
}
"""

    nft_path = "/etc/nftables.d/vpn007-forwarding.nft"
    os.makedirs("/etc/nftables.d", exist_ok=True)
    with open(nft_path, "w") as f:
        f.write(rules)

    # Apply the rules atomically
    run_cmd(["nft", "-f", nft_path])
    log.info("nftables port-forwarding rules applied from %s.", nft_path)


def _configure_nftables_all_traffic(tunnel_peer_ip: str) -> None:
    """Configure full-traffic forwarding through the tunnel.

    All outbound traffic from VPN client interfaces (Docker bridge, AmneziaWG,
    Tailscale) is routed through the tunnel to the exit node. The cover website
    and management panels continue to respond from this VM's own IP.

    Implementation:
    - Mark packets from VPN client subnets (Docker 172.16.0.0/12, WireGuard
      10.x.x.x) using nftables mangle.
    - Use a policy routing table (table 100) that routes marked packets through
      the tunnel interface.
    - Masquerade on the tunnel interface for NAT.
    """
    # Determine the tunnel interface name
    match TUNNEL_TYPE:
        case "wireguard":
            tunnel_iface = "wg-tunnel"
        case "tailscale":
            tunnel_iface = "tailscale0"
        case _:
            tunnel_iface = "wg-tunnel"

    # Build nftables rules for marking + NAT
    rules = """#!/usr/sbin/nft -f
# VPN007 forwarding rules (mode: all) — generated by VPN007
# Routes all VPN client traffic through the tunnel to the exit node.
# Do not edit manually; re-run the forwarding script to regenerate.

table ip vpn007_forward {
    chain prerouting {
        type filter hook prerouting priority mangle; policy accept;
        # Mark traffic from Docker bridge networks (VPN containers)
        ip saddr 172.16.0.0/12 meta mark set 0x007
        # Mark traffic from WireGuard/AmneziaWG client subnets
        ip saddr 10.0.0.0/8 meta mark set 0x007
    }

    chain postrouting {
        type nat hook postrouting priority 100; policy accept;
        # Masquerade all traffic going out through the tunnel
"""
    rules += f'        oifname "{tunnel_iface}" masquerade\n'
    rules += """    }

    chain forward {
        type filter hook forward priority 0; policy accept;
        # Allow established/related
        ct state established,related accept
        # Allow marked traffic to be forwarded through the tunnel
"""
    rules += f'        meta mark 0x007 oifname "{tunnel_iface}" accept\n'
    rules += """    }
}
"""

    nft_path = "/etc/nftables.d/vpn007-forwarding.nft"
    os.makedirs("/etc/nftables.d", exist_ok=True)
    with open(nft_path, "w") as f:
        f.write(rules)

    # Apply the rules atomically
    run_cmd(["nft", "-f", nft_path])
    log.info("nftables all-traffic forwarding rules applied from %s.", nft_path)

    # Set up policy routing: marked packets use routing table 100
    # which has the tunnel peer as default gateway.
    log.info("Configuring policy routing (table 100) via %s...", tunnel_peer_ip)

    # Add routing rule: packets with mark 0x007 use table 100
    run_cmd(["ip", "rule", "del", "fwmark", "0x007", "table", "100"], check=False)
    run_cmd(["ip", "rule", "add", "fwmark", "0x007", "table", "100"])

    # Add default route in table 100 via the tunnel peer
    run_cmd(["ip", "route", "replace", "default", "via", tunnel_peer_ip, "table", "100"])

    log.info("Policy routing configured: marked traffic → %s (table 100).", tunnel_peer_ip)


# ---------------------------------------------------------------------------
# Reconnection with exponential backoff
# ---------------------------------------------------------------------------

def check_tunnel_health() -> bool:
    """Check whether the tunnel to the primary VM is healthy."""
    match TUNNEL_TYPE:
        case "wireguard":
            result = run_cmd(
                ["ping", "-c", "1", "-W", "3", WG_REMOTE_IP],
                check=False,
                capture=True,
            )
            return result.returncode == 0
        case "ssh":
            # For SSH, check if autossh process is running
            result = run_cmd(
                ["pgrep", "-f", "autossh"],
                check=False,
                capture=True,
            )
            return result.returncode == 0
        case "tailscale":
            result = run_cmd(
                ["tailscale", "ping", "--timeout=3s", PRIMARY_VM_IP],
                check=False,
                capture=True,
            )
            return result.returncode == 0
        case "xray":
            # Check if the Xray tunnel service is running
            result = run_cmd(
                ["systemctl", "is-active", "vpn007-xray-tunnel.service"],
                check=False,
                capture=True,
            )
            return result.returncode == 0
        case _:
            return False


def reconnect_tunnel() -> None:
    """Attempt to re-establish the tunnel."""
    log.info("Attempting to reconnect tunnel...")
    match TUNNEL_TYPE:
        case "wireguard":
            run_cmd(["wg-quick", "down", "wg-tunnel"], check=False)
            run_cmd(["wg-quick", "up", "wg-tunnel"])
        case "ssh":
            # Kill existing autossh and restart
            run_cmd(["pkill", "-f", "autossh"], check=False)
            time.sleep(1)
            setup_ssh_tunnel()
        case "tailscale":
            run_cmd(["tailscale", "down"], check=False)
            time.sleep(1)
            run_cmd(["tailscale", "up"])
        case "xray":
            run_cmd(["systemctl", "restart", "vpn007-xray-tunnel.service"])


def monitor_and_reconnect() -> None:
    """Monitor tunnel health and reconnect with exponential backoff.

    Uses exponential backoff: delay starts at RECONNECT_INITIAL_DELAY and
    doubles on each consecutive failure, capped at RECONNECT_MAX_DELAY.
    Resets to initial delay on successful reconnection.
    """
    delay = RECONNECT_INITIAL_DELAY
    log.info(
        "Starting tunnel health monitor (initial_delay=%ds, max_delay=%ds)...",
        RECONNECT_INITIAL_DELAY,
        RECONNECT_MAX_DELAY,
    )

    while True:
        time.sleep(delay)

        if check_tunnel_health():
            if delay != RECONNECT_INITIAL_DELAY:
                log.info("Tunnel is healthy. Resetting backoff delay.")
            delay = RECONNECT_INITIAL_DELAY
        else:
            log.warning(
                "Tunnel health check failed. Reconnecting in %ds...", delay
            )
            try:
                reconnect_tunnel()
                log.info("Reconnection attempt completed.")
            except Exception as exc:
                log.error("Reconnection failed: %s", exc)
            delay = min(delay * 2, RECONNECT_MAX_DELAY)


# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------

def main() -> None:
    """Main entry point for the forwarding script."""
    log.info("=" * 60)
    log.info("VPN007 Inter-VM Forwarding Installer")
    log.info("=" * 60)
    log.info("Primary VM IP:    %s", PRIMARY_VM_IP)
    log.info("Exit node host:   %s", EXIT_NODE_HOST)
    log.info("Tunnel type:      %s", TUNNEL_TYPE)
    log.info("Forwarding mode:  %s", FORWARDING_MODE)
    log.info("Reverse initiated: %s", REVERSE_INITIATED)
    log.info("Port forwards:    %d rules", len(FORWARDING_PORTS))
    log.info("Reconnect delay:  %ds initial, %ds max", RECONNECT_INITIAL_DELAY, RECONNECT_MAX_DELAY)
    log.info("-" * 60)

    # Check root
    if os.geteuid() != 0:
        log.error("This script must be run as root.")
        sys.exit(1)

    # Step 1: Install tunnel endpoint
    log.info("[Step 1/4] Installing tunnel endpoint...")
    install_tunnel_endpoint()

    # Step 2: Set up the tunnel
    log.info("[Step 2/4] Setting up encrypted tunnel...")
    setup_tunnel()

    # Step 3: Configure nftables forwarding rules
    log.info("[Step 3/4] Configuring nftables DNAT/SNAT rules...")
    configure_nftables_forwarding()

    # Step 4: Start monitoring and reconnection
    log.info("[Step 4/4] Starting tunnel health monitor...")
    log.info("Forwarding is active. Press Ctrl+C to stop.")
    try:
        monitor_and_reconnect()
    except KeyboardInterrupt:
        log.info("Shutting down forwarding monitor.")
        sys.exit(0)


if __name__ == "__main__":
    main()
