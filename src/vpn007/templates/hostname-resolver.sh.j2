{# Template: hostname-resolver.sh — Hostname to IP resolver for panel access control #}
{# © Vadim Pavlov 2026 #}
#!/usr/bin/env bash
# Hostname resolver — resolves hostnames to IPs for Nginx panel access control.
# Generated by VPN007. © Vadim Pavlov 2026
set -euo pipefail

LOG_TAG="vpn007-hostname-resolver"
CONF_FILE="{{ nginx_conf_dir }}/approved_panel_ips.conf"
CONF_TMP="${CONF_FILE}.tmp.$$"
COMPOSE_DIR="{{ compose_dir }}"

# Hostnames to resolve
HOSTNAMES=(
{% for hostname in hostnames %}
    "{{ hostname }}"
{% endfor %}
)

# Static approved IPs (always included)
STATIC_IPS=(
{% for ip in static_ips %}
    "{{ ip }}"
{% endfor %}
)

log_info() {
    logger -t "${LOG_TAG}" -p user.info "$1"
    echo "[INFO] $1"
}

log_warn() {
    logger -t "${LOG_TAG}" -p user.warning "$1"
    echo "[WARN] $1" >&2
}

# Build the new approved IPs config
{
    echo "# Auto-generated by VPN007 hostname resolver"
    echo "# Do not edit manually — changes will be overwritten"
    echo ""

    # Static IPs
    for ip in "${STATIC_IPS[@]+"${STATIC_IPS[@]}"}"; do
        [ -n "$ip" ] && echo "allow ${ip};"
    done

    # Resolved hostnames
    for hostname in "${HOSTNAMES[@]+"${HOSTNAMES[@]}"}"; do
        [ -z "$hostname" ] && continue
        resolved=$(dig +short "$hostname" A 2>/dev/null | grep -E '^[0-9]+\.' || true)
        resolved_v6=$(dig +short "$hostname" AAAA 2>/dev/null | grep -E '^[0-9a-f:]+$' || true)

        if [ -z "${resolved}" ] && [ -z "${resolved_v6}" ]; then
            log_warn "Could not resolve ${hostname} — skipping"
            continue
        fi

        echo "# ${hostname}"
        for ip in ${resolved}; do
            echo "allow ${ip};"
        done
        for ip in ${resolved_v6}; do
            echo "allow ${ip};"
        done
    done
} > "${CONF_TMP}"

# Check if the config has changed
if [ -f "${CONF_FILE}" ] && diff -q "${CONF_FILE}" "${CONF_TMP}" > /dev/null 2>&1; then
    log_info "No changes in resolved IPs — Nginx reload not needed"
    rm -f "${CONF_TMP}"
    exit 0
fi

# Apply the new config
mv "${CONF_TMP}" "${CONF_FILE}"
log_info "Updated approved panel IPs configuration"

# Reload Nginx to pick up the new IPs
if docker compose -f "${COMPOSE_DIR}/docker-compose.yml" exec reverse_proxy nginx -s reload 2>/dev/null; then
    log_info "Nginx reloaded successfully"
else
    log_warn "Failed to reload Nginx — config will take effect on next restart"
fi
