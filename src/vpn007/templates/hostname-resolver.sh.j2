{# Template: hostname-resolver.sh — Hostname to IP resolver for panel and SSH access control #}
{# © Vadim Pavlov 2026 #}
#!/usr/bin/env bash
# Hostname resolver — resolves hostnames to IPs for Nginx panel access and nftables SSH access.
# Generated by VPN007. © Vadim Pavlov 2026
set -euo pipefail

LOG_TAG="vpn007-hostname-resolver"
CONF_FILE="{{ nginx_conf_dir }}/approved_panel_ips.conf"
CONF_TMP="${CONF_FILE}.tmp.$$"
COMPOSE_DIR="{{ compose_dir }}"

# Panel hostnames to resolve
PANEL_HOSTNAMES=(
{% for hostname in hostnames %}
    "{{ hostname }}"
{% endfor %}
)

# Static approved panel IPs (always included)
PANEL_STATIC_IPS=(
{% for ip in static_ips %}
    "{{ ip }}"
{% endfor %}
)

# SSH hostnames to resolve
SSH_HOSTNAMES=(
{% for hostname in ssh_hostnames %}
    "{{ hostname }}"
{% endfor %}
)

# Static SSH approved IPs (always included in nftables set)
SSH_STATIC_IPS=(
{% for ip in ssh_static_ips %}
    "{{ ip }}"
{% endfor %}
)

log_info() {
    logger -t "${LOG_TAG}" -p user.info "$1"
    echo "[INFO] $1"
}

log_warn() {
    logger -t "${LOG_TAG}" -p user.warning "$1"
    echo "[WARN] $1" >&2
}

# ---------------------------------------------------------------------------
# Resolve a list of hostnames to IPv4 addresses
# ---------------------------------------------------------------------------
resolve_hostnames_v4() {
    local -n _hostnames=$1
    local resolved=""
    for hostname in "${_hostnames[@]+"${_hostnames[@]}"}"; do
        [ -z "$hostname" ] && continue
        local ips
        ips=$(dig +short "$hostname" A 2>/dev/null | grep -E '^[0-9]+\.' || true)
        if [ -z "$ips" ]; then
            log_warn "Could not resolve ${hostname} — skipping"
            continue
        fi
        for ip in $ips; do
            resolved="${resolved} ${ip}"
        done
    done
    echo "$resolved"
}

# ---------------------------------------------------------------------------
# Part 1: Update Nginx panel access (approved_panel_ips.conf)
# ---------------------------------------------------------------------------
update_panel_access() {
    {
        echo "# Auto-generated by VPN007 hostname resolver"
        echo "# Do not edit manually — changes will be overwritten"
        echo ""

        # Static IPs
        for ip in "${PANEL_STATIC_IPS[@]+"${PANEL_STATIC_IPS[@]}"}"; do
            [ -n "$ip" ] && echo "allow ${ip};"
        done

        # Resolved hostnames
        for hostname in "${PANEL_HOSTNAMES[@]+"${PANEL_HOSTNAMES[@]}"}"; do
            [ -z "$hostname" ] && continue
            local resolved
            resolved=$(dig +short "$hostname" A 2>/dev/null | grep -E '^[0-9]+\.' || true)
            local resolved_v6
            resolved_v6=$(dig +short "$hostname" AAAA 2>/dev/null | grep -E '^[0-9a-f:]+' || true)

            if [ -z "${resolved}" ] && [ -z "${resolved_v6}" ]; then
                log_warn "Could not resolve ${hostname} — skipping"
                continue
            fi

            echo "# ${hostname}"
            for ip in ${resolved}; do
                echo "allow ${ip};"
            done
            for ip in ${resolved_v6}; do
                echo "allow ${ip};"
            done
        done
    } > "${CONF_TMP}"

    # Check if the config has changed
    if [ -f "${CONF_FILE}" ] && diff -q "${CONF_FILE}" "${CONF_TMP}" > /dev/null 2>&1; then
        log_info "Panel IPs: no changes — Nginx reload not needed"
        rm -f "${CONF_TMP}"
        return 0
    fi

    # Apply the new config
    mv "${CONF_TMP}" "${CONF_FILE}"
    log_info "Updated approved panel IPs configuration"

    # Reload Nginx to pick up the new IPs
    if docker compose -f "${COMPOSE_DIR}/docker-compose.yml" exec reverse_proxy nginx -s reload 2>/dev/null; then
        log_info "Nginx reloaded successfully"
    else
        log_warn "Failed to reload Nginx — config will take effect on next restart"
    fi
}

# ---------------------------------------------------------------------------
# Part 2: Update nftables SSH access (approved_ssh_v4 set)
# ---------------------------------------------------------------------------
update_ssh_access() {
    # Only update if SSH hostnames or static IPs are configured
{% raw %}
    if [ ${#SSH_HOSTNAMES[@]} -eq 0 ] && [ ${#SSH_STATIC_IPS[@]} -eq 0 ]; then
{% endraw %}
        return 0
    fi

    # Collect all SSH-approved IPs (static + resolved)
    local all_ssh_ips=""

    for ip in "${SSH_STATIC_IPS[@]+"${SSH_STATIC_IPS[@]}"}"; do
        [ -n "$ip" ] && all_ssh_ips="${all_ssh_ips} ${ip}"
    done

    local resolved_ssh
    resolved_ssh=$(resolve_hostnames_v4 SSH_HOSTNAMES)
    all_ssh_ips="${all_ssh_ips} ${resolved_ssh}"

    # Trim whitespace
    all_ssh_ips=$(echo "$all_ssh_ips" | xargs)

    if [ -z "$all_ssh_ips" ]; then
        log_warn "SSH: no IPs resolved — keeping existing rules"
        return 0
    fi

    # Build nftables atomic update file
    local nft_tmp="/tmp/vpn007-ssh-update.$$.nft"
    {
        echo "flush set inet filter approved_ssh_v4"
        local elements=""
        for ip in $all_ssh_ips; do
            if [ -n "$elements" ]; then
                elements="${elements}, ${ip}"
            else
                elements="${ip}"
            fi
        done
        echo "add element inet filter approved_ssh_v4 { ${elements} }"
    } > "$nft_tmp"

    # Apply atomically
    if nft -f "$nft_tmp" 2>/dev/null; then
        log_info "SSH approved IPs updated: ${all_ssh_ips}"
    else
        log_warn "Failed to update nftables SSH set — keeping existing rules"
    fi

    rm -f "$nft_tmp"
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
log_info "Starting hostname resolution..."

update_panel_access
update_ssh_access

log_info "Hostname resolution complete."
