{# Template: blocklist-updater.sh — AS number prefix resolver and nftables set updater script #}
{# © Vadim Pavlov 2026 #}
#!/usr/bin/env bash
# Blocklist updater — resolves AS numbers to IP prefixes and updates nftables named sets.
# Generated by VPN007. © Vadim Pavlov 2026
set -euo pipefail

LOG_TAG="vpn007-blocklist-updater"
CACHE_DIR="/var/lib/vpn007/blocklist"
CACHE_FILE_V4="${CACHE_DIR}/blocked_v4.txt"
CACHE_FILE_V6="${CACHE_DIR}/blocked_v6.txt"
NFT_TMP="/tmp/vpn007-blocklist-update.$$.nft"

# AS numbers to resolve
AS_NUMBERS=(
{% for asn in as_numbers %}
    "{{ asn }}"
{% endfor %}
)

# Static blocked subnets (always included)
STATIC_V4=(
{% for subnet in static_v4_subnets %}
    "{{ subnet }}"
{% endfor %}
)

STATIC_V6=(
{% for subnet in static_v6_subnets %}
    "{{ subnet }}"
{% endfor %}
)

{% raw %}
log_info() {
    logger -t "${LOG_TAG}" -p user.info "$1"
    echo "[INFO] $1"
}

log_warn() {
    logger -t "${LOG_TAG}" -p user.warning "$1"
    echo "[WARN] $1" >&2
}

log_error() {
    logger -t "${LOG_TAG}" -p user.err "$1"
    echo "[ERROR] $1" >&2
}

mkdir -p "${CACHE_DIR}"

# Resolve AS numbers to prefixes via whois (primary) or RIPE RIS API (fallback)
resolve_as_prefixes() {
    local asn="$1"
    local asn_num="${asn#AS}"
    local prefixes=""

    # Primary: RADB whois
    prefixes=$(whois -h whois.radb.net -- -i origin "AS${asn_num}" 2>/dev/null \
        | grep -E '^route6?:' \
        | awk '{print $2}' \
        | sort -u) || true

    if [ -n "${prefixes}" ]; then
        echo "${prefixes}"
        return 0
    fi

    # Fallback: RIPE RIS API
    local api_url="https://stat.ripe.net/data/announced-prefixes/data.json?resource=AS${asn_num}"
    local api_response
    api_response=$(curl -s -m 30 "${api_url}" 2>/dev/null) || true

    if [ -n "${api_response}" ]; then
        prefixes=$(echo "${api_response}" \
            | python3 -c "
import sys, json
try:
    data = json.load(sys.stdin)
    for p in data.get('data', {}).get('prefixes', []):
        print(p.get('prefix', ''))
except Exception:
    pass
" | sort -u) || true
        if [ -n "${prefixes}" ]; then
            echo "${prefixes}"
            return 0
        fi
    fi

    return 1
}

# Collect all resolved prefixes
ALL_V4=()
ALL_V6=()

# Add static subnets
for s in "${STATIC_V4[@]+"${STATIC_V4[@]}"}"; do
    [ -n "$s" ] && ALL_V4+=("$s")
done
for s in "${STATIC_V6[@]+"${STATIC_V6[@]}"}"; do
    [ -n "$s" ] && ALL_V6+=("$s")
done

resolution_failed=0

for asn in "${AS_NUMBERS[@]+"${AS_NUMBERS[@]}"}"; do
    [ -z "$asn" ] && continue
    log_info "Resolving prefixes for ${asn}..."
    resolved=$(resolve_as_prefixes "${asn}") || {
        log_warn "Failed to resolve ${asn} from any source"
        resolution_failed=1
        continue
    }

    while IFS= read -r prefix; do
        [ -z "${prefix}" ] && continue
        if echo "${prefix}" | grep -q ':'; then
            ALL_V6+=("${prefix}")
        else
            ALL_V4+=("${prefix}")
        fi
    done <<< "${resolved}"
    log_info "Resolved ${asn}: $(echo "${resolved}" | wc -l | tr -d ' ') prefixes"
done

# If all resolution sources failed and we have no new prefixes beyond static,
# keep existing rules unchanged
as_count=${#AS_NUMBERS[@]}
if [ "${resolution_failed}" -eq 1 ] && [ "${as_count}" -gt 0 ]; then
    static_count=$(( ${#STATIC_V4[@]} + ${#STATIC_V6[@]} ))
    resolved_count=$(( ${#ALL_V4[@]} + ${#ALL_V6[@]} ))
    if [ "${resolved_count}" -le "${static_count}" ]; then
        log_warn "All AS resolution sources unreachable. Keeping existing rules unchanged."
        exit 0
    fi
fi

# Compare with cached results to log changes
if [ -f "${CACHE_FILE_V4}" ]; then
    old_v4=$(cat "${CACHE_FILE_V4}")
    new_v4=$(printf '%s\n' "${ALL_V4[@]+"${ALL_V4[@]}"}" | sort -u)
    added=$(comm -13 <(echo "${old_v4}" | sort) <(echo "${new_v4}" | sort) | grep -v '^$' || true)
    removed=$(comm -23 <(echo "${old_v4}" | sort) <(echo "${new_v4}" | sort) | grep -v '^$' || true)
    [ -n "${added}" ] && log_info "Added IPv4 prefixes: ${added}"
    [ -n "${removed}" ] && log_info "Removed IPv4 prefixes: ${removed}"
fi

if [ -f "${CACHE_FILE_V6}" ]; then
    old_v6=$(cat "${CACHE_FILE_V6}")
    new_v6=$(printf '%s\n' "${ALL_V6[@]+"${ALL_V6[@]}"}" | sort -u)
    added=$(comm -13 <(echo "${old_v6}" | sort) <(echo "${new_v6}" | sort) | grep -v '^$' || true)
    removed=$(comm -23 <(echo "${old_v6}" | sort) <(echo "${new_v6}" | sort) | grep -v '^$' || true)
    [ -n "${added}" ] && log_info "Added IPv6 prefixes: ${added}"
    [ -n "${removed}" ] && log_info "Removed IPv6 prefixes: ${removed}"
fi

# Build atomic nftables update file
cat > "${NFT_TMP}" << 'NFTEOF'
flush set inet filter blocked_v4
flush set inet filter blocked_v6
NFTEOF

v4_count=${#ALL_V4[@]}
if [ "${v4_count}" -gt 0 ]; then
    {
        echo "add element inet filter blocked_v4 {"
        printf '    %s,\n' "${ALL_V4[@]}"
        echo "}"
    } >> "${NFT_TMP}"
fi

v6_count=${#ALL_V6[@]}
if [ "${v6_count}" -gt 0 ]; then
    {
        echo "add element inet filter blocked_v6 {"
        printf '    %s,\n' "${ALL_V6[@]}"
        echo "}"
    } >> "${NFT_TMP}"
fi

# Apply atomically
if nft -f "${NFT_TMP}"; then
    log_info "nftables blocked sets updated successfully"
else
    log_error "Failed to apply nftables update"
    rm -f "${NFT_TMP}"
    exit 1
fi

rm -f "${NFT_TMP}"

# Cache current results for next comparison
printf '%s\n' "${ALL_V4[@]+"${ALL_V4[@]}"}" | sort -u > "${CACHE_FILE_V4}"
printf '%s\n' "${ALL_V6[@]+"${ALL_V6[@]}"}" | sort -u > "${CACHE_FILE_V6}"

log_info "Blocklist update complete: ${v4_count} IPv4, ${v6_count} IPv6 prefixes"
{% endraw %}
