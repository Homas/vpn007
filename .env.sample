#
# VPN007 — Sample Environment File
# ==================================
# Copy this file to .env and edit the values for your deployment.
#
# Parameters marked REQUIRED have no default and must be set.
# All other parameters show their default values — uncomment and change
# only if you need to override the default.
#
# NOTE: Port 80 is NOT permanently open. It is only opened dynamically
# during certbot certificate renewal (via pre/post hooks in the renewal
# script) to reduce DPI fingerprinting surface. At all other times,
# port 80 is DROPped by the nftables firewall.
#
# Set AUTO_INSTALL=y to skip interactive prompts (for scripted deployments).
# AUTO_INSTALL=y

# ============================================================================
# GENERAL
# ============================================================================

# REQUIRED — Primary domain name for the VPN server.
# A valid DNS A/AAAA record must point to this VM's public IP.
DOMAIN=vpn.example.com

# Reality SNI target — a popular website that supports TLS 1.3.
# Choose a site hosted on the same or nearby AS as your VPN server.
# Avoid commonly known Reality SNI targets. The deployer validates
# TLS 1.3 support during deployment.
# Default: www.microsoft.com
REALITY_SNI=www.microsoft.com

# Cover site mode: "static" or "proxy".
#   static — serve local static files from COVER_SITE_STATIC_PATH
#   proxy  — reverse-proxy to an external legitimate website (COVER_SITE_URL)
#
# In proxy mode, anti-detection measures are applied automatically:
#   - Host header is rewritten to match the target domain
#   - Static assets are cached aggressively to behave like a true origin server
# Default: static
COVER_SITE_MODE=static

# URL of the external website to proxy (only used when COVER_SITE_MODE=proxy).
# No default — required only when COVER_SITE_MODE=proxy.
# COVER_SITE_URL=https://www.example.org

# Path to local static files (only used when COVER_SITE_MODE=static).
# No default — optional; if omitted, a placeholder page is served.
# COVER_SITE_STATIC_PATH=/var/www/html

# ============================================================================
# ROUTING PATHS
# ============================================================================

# URL path prefix for the 3x-ui web panel.
# Must start with "/". Keep it secret — this is your admin panel.
# If not set, a random 6-character suffix is appended (e.g., /secretpanel-a7f3b2)
# to prevent probing by adversaries who know the tool.
# Default: /secretpanel-<random>
XUI_PATH_PREFIX=/secretpanel

# URL path prefix for the AmneziaWG web panel.
# Must start with "/". Keep it secret.
# If not set, a random 6-character suffix is appended (e.g., /awgadmin-c9e1d4).
# Default: /awgadmin-<random>
AWG_PANEL_PATH_PREFIX=/awgadmin

# Enable the optional secondary HTTPS port 8443.
# Disabled by default to reduce fingerprinting surface — most legitimate
# websites only listen on 443. Enable only if you need it.
# Default: false
ENABLE_PORT_8443=false

# ============================================================================
# XRAY / REALITY
# ============================================================================

# Internal port for Xray VLESS+Reality connections (container-internal).
# You generally don't need to change this.
# Default: 10443
XRAY_INTERNAL_PORT=10443

# ============================================================================
# AMNEZIAWG
# ============================================================================

# UDP listen port for AmneziaWG on the host.
# Default: random high port (10000-65535) generated at deploy time to avoid
# standard WireGuard fingerprinting — DPI systems commonly probe port 51820.
# Set a fixed port if you need predictable firewall rules on client networks.
# Default: (random 10000-65535)
# AWG_LISTEN_PORT=51820

# AmneziaWG web panel port (local-only, accessed via reverse proxy).
# Default: 51821
AWG_PANEL_PORT=51821

# AmneziaWG 2.0 obfuscation parameters.
# If omitted, random values within valid ranges are generated automatically.
# All S1-S4 and H1-H4 must be provided together, or omit all for auto-generation.
#
# Packet size parameters (must match between server and clients):
# AWG_S1=56        # Random prefix for Init packets (0-1132, recommended 15-150)
# AWG_S2=78        # Random prefix for Response packets (0-1188, recommended 15-150)
# AWG_S3=34        # Random prefix for Cookie packets (0-1216, recommended 15-150)
# AWG_S4=12        # Random prefix for Data packets (0-32)
# AWG_H1=12345678  # Dynamic header for Init packets (5-2147483647)
# AWG_H2=87654321  # Dynamic header for Response packets (5-2147483647)
# AWG_H3=11223344  # Dynamic header for Cookie packets (5-2147483647)
# AWG_H4=44332211  # Dynamic header for Data packets (5-2147483647)
#
# Junk packet parameters (can differ between server and clients):
# AWG_JC=6         # Junk packet count (1-128, recommended 4-10)
# AWG_JMIN=50      # Min junk packet size (0-1280)
# AWG_JMAX=1000    # Max junk packet size (0-1280, must be > JMIN)
#
# CPS Signature Packets (I1-I5) — Protocol Imitation
# These make AmneziaWG traffic look like a known UDP protocol to DPI systems.
# Format: CPS (Custom Protocol Signature) using tags:
#   <b 0xHEX>  — static bytes (protocol header)
#   <r N>      — N random bytes
#   <t>        — Unix timestamp (32-bit)
#   <rc N>     — N random ASCII letters
#   <rd N>     — N random digits
#
# Default: WebRTC/STUN Binding Request (most effective for bypassing DPI).
# STUN is used by all WebRTC applications (video calls, screen sharing) and
# is never blocked because it would break Google Meet, Zoom, Teams, etc.
#
# Recommended protocols for I1:
#   WebRTC/STUN: <b 0x000100002112a442><r 12>
#   DNS query:   <r 2><b 0x8580000100010000000004796162730679616e6465780272750000010001c00c000100010000026d000457fa27d1>
#   QUIC Initial: capture with Wireshark (filter: quic), copy hex, wrap in <b 0x...>
#
# I2-I5 add entropy (random data, timestamps) to simulate multi-packet exchanges.
# Default values (WebRTC/STUN) are auto-generated if omitted:
#   AWG_I1=<b 0x000100002112a442><r 12>
#   AWG_I2=<b 0x0101><r 4><t><r 8>
#   AWG_I3=<r 32>
# Uncomment and change only if you want a different protocol signature:
# AWG_I1=<b 0x000100002112a442><r 12>
# AWG_I2=<b 0x0101><r 4><t><r 8>
# AWG_I3=<r 32>

# ============================================================================
# TAILSCALE
# ============================================================================

# Tailscale auth key for automatic node registration.
# Generate at https://login.tailscale.com/admin/settings/keys
# If left empty, the container will log a URL for manual authentication.
# For unattended/scripted deployments, provide an auth key.
TAILSCALE_AUTH_KEY=

# Hostname for this node in the tailnet.
# If empty, Tailscale uses the system hostname.
# Default: (empty — uses system hostname)
TAILSCALE_HOSTNAME=

# Extra arguments passed to the Tailscale daemon.
# Default: --advertise-exit-node (advertises this node as an exit node).
# Add --accept-routes to accept routes from other nodes, or
# --advertise-routes=10.0.0.0/24 to share local subnets.
TAILSCALE_EXTRA_ARGS=--advertise-exit-node

# ============================================================================
# MULTI-IP CONFIGURATION
# ============================================================================

# Bind the reverse proxy to a specific incoming IP address.
# Use the private (interface) IP if the VM is behind NAT.
# Default: (empty — binds to all interfaces)
# INCOMING_IP=10.0.0.2

# Source IP for outbound traffic from VPN services.
# Useful when the VM has multiple IPs and you want inbound/outbound
# traffic to use different addresses for improved privacy.
# Default: (empty — uses default route)
# OUTGOING_IP=10.0.0.3

# Public IPv4 address of the VM (used in client configs and DNS records).
# Default: auto-detected via curl -4 ifconfig.me
# PUBLIC_IPV4=203.0.113.10

# Public IPv6 address of the VM (used in client configs and DNS records).
# Default: auto-detected via curl -6 ifconfig.me (optional)
# PUBLIC_IPV6=2001:db8::1

# ============================================================================
# TLS CONFIGURATION
# ============================================================================

# Accepted TLS versions (comma-separated).
# TLS 1.2 fallback helps in environments where Russia's TSPU/DPI blocks
# or throttles TLS 1.3 sessions. ECH/ESNI extensions are never advertised
# (actively blocked by TSPU since November 2024).
# When both versions are enabled, TLS 1.3 cipher suites are preferred.
# TLS 1.2 uses only strong ciphers: ECDHE+AESGCM, ECDHE+CHACHA20POLY1305.
# Default: 1.2,1.3
TLS_VERSIONS=1.2,1.3

# Skip Let's Encrypt certificate acquisition. When true, the deployment
# uses a self-signed certificate only. Useful for lab/staging environments
# without a real domain name or public DNS.
# Default: false
SKIP_CERTBOT=false

# Main HTTPS listen port.
# Change for lab/staging environments where port 443 is already in use.
# Default: 443
HTTPS_PORT=443

# ============================================================================
# ACCESS CONTROL
# ============================================================================

# Comma-separated list of IP addresses and subnets approved for web panel
# access (3x-ui and AmneziaWG management panels). Connections from other IPs
# get 403 Forbidden. This is enforced at the Nginx level (allow/deny directives),
# completely independent of SSH access.
# No default — if empty, panels are accessible from any IP (not recommended).
APPROVED_IPS=203.0.113.50,198.51.100.0/24

# Comma-separated list of hostnames approved for web panel access.
# Hostnames are resolved to IPs periodically (see HOSTNAME_RESOLVE_INTERVAL_MIN).
# Useful for operators with dynamic IPs who have a DDNS hostname.
# Default: (empty)
APPROVED_HOSTNAMES=admin.example.com,home.example.net

# Comma-separated list of IPs allowed to SSH into the VM.
# This is enforced at the nftables firewall level (port 22), completely
# independent of panel access (APPROVED_IPS).
# If empty or omitted, SSH is open from all networks (default).
# Set this to restrict SSH to specific management IPs.
# Default: (empty — SSH open to all)
# SSH_APPROVED_IPS=203.0.113.50

# Comma-separated list of hostnames allowed to SSH into the VM.
# Hostnames are resolved to IPs periodically (same interval as panel hostnames).
# Useful for operators with dynamic IPs who have a DDNS hostname.
# Default: (empty)
# SSH_APPROVED_HOSTNAMES=admin.example.com

# How often (in minutes) to re-resolve approved hostnames to IP addresses.
# The hostname resolver updates the Nginx include file and reloads the
# reverse proxy if resolved addresses change.
# Default: 30
HOSTNAME_RESOLVE_INTERVAL_MIN=30

# ============================================================================
# FIREWALL / AS & SUBNET BLOCKING
# ============================================================================

# Comma-separated list of Autonomous System numbers to block.
# All IP prefixes announced by these ASes are resolved and added to
# nftables block rules (both inbound and outbound).
#
# Example AS numbers for blocking known Russian surveillance/monitoring networks:
#   AS196747 — FGUP 'GRCHC' (GRFC-AS), General Radio Frequency Centre
#   AS61280  — RTK-Solar (Rostelecom Solar), cybersecurity/monitoring division
#   AS213853 — TSPU/TSPD infrastructure (DPI filtering nodes)
#   AS196641 — GRFC monitoring infrastructure
# Blocking these reduces probe exposure from state-operated network monitoring.
# Default: (empty)
BLOCKED_AS_NUMBERS=AS196747,AS61280,AS213853,AS196641

# Comma-separated list of IP subnets to block directly.
# Added to nftables named sets alongside resolved AS prefixes.
# Default: (empty)
# BLOCKED_SUBNETS=192.0.2.0/24,198.51.100.0/24

# How often (in hours) the blocklist updater re-resolves AS numbers
# to current IP prefixes and updates nftables named sets.
# Default: 6
BLOCKLIST_UPDATE_INTERVAL_HOURS=6

# ============================================================================
# ENCRYPTED TRAFFIC FORWARDING (INTER-VM)
# ============================================================================

# Enable traffic forwarding to a secondary VM.
# Default: false
FORWARDING_ENABLED=false

# Forwarding mode: "ports" or "all".
#   ports — forward specific ports via DNAT rules (requires FORWARDING_PORTS)
#   all   — route all VPN client traffic through the tunnel (full-traffic mode)
#
# In "all" mode, VPN client traffic (from Docker bridge and AmneziaWG subnets)
# is policy-routed through the tunnel to the exit node. The cover website and
# management panels still respond from this VM's own IP.
# Note: "all" mode requires tunnel_type wireguard or tailscale (not ssh).
# Default: ports
# FORWARDING_MODE=ports

# Tunnel type for inter-VM encrypted forwarding: wireguard, ssh, tailscale, or xray.
# Required when FORWARDING_ENABLED=true.
# Note: ssh is only supported with FORWARDING_MODE=ports.
# Note: xray (VLESS+Reality) makes the inter-node link indistinguishable from
#       legitimate TLS 1.3 traffic — best for censored networks.
# TUNNEL_TYPE=wireguard

# IP address or hostname of the exit node (secondary VM).
# Accepts both IP addresses (e.g., 198.51.100.20) and hostnames (e.g., exit.example.com).
# Required when FORWARDING_ENABLED=true.
# EXIT_NODE_HOST=198.51.100.20

# Enable reverse-initiated connections: the secondary VM initiates the
# tunnel back to the primary VM. Useful when the secondary VM is behind
# NAT or a restrictive firewall.
# Default: false
REVERSE_INITIATED=false

# Comma-separated port forwarding rules.
# Format: protocol:listen_port:forward_port:description
# Required when FORWARDING_ENABLED=true.
# FORWARDING_PORTS=tcp:443:443:HTTPS,udp:51820:51820:WireGuard

# Reconnection parameters for the encrypted tunnel (exponential backoff).
# Default: 5 seconds initial, 300 seconds max
RECONNECT_INITIAL_DELAY_SEC=5
RECONNECT_MAX_DELAY_SEC=300

# Tunnel subnet for the WireGuard point-to-point link between VMs.
# Change this if you have multiple tunnels or subnet conflicts.
# Default: 10.99.0.0/30
# TUNNEL_SUBNET=10.99.0.0/30

# SNI target for the inter-node VLESS+Reality tunnel (only used when TUNNEL_TYPE=xray).
# Choose a popular website that supports TLS 1.3. Can differ from the
# client-facing REALITY_SNI for operational separation.
# Default: same as REALITY_SNI
# TUNNEL_XRAY_SNI=www.google.com

# Port on the exit node for the VLESS+Reality tunnel (only used when TUNNEL_TYPE=xray).
# Default: 443 (blends with normal HTTPS traffic)
# TUNNEL_XRAY_PORT=443

# ============================================================================
# EXIT NODE ROLE (DUAL-ROLE: THIS VM ALSO SERVES AS EXIT FOR ANOTHER)
# ============================================================================

# Enable exit node role: this VM accepts forwarded traffic from another
# VPN007 node while simultaneously running its own VPN stack.
# Use case: VM-A and VM-B both run VPN007 for their own clients, and
# VM-A also serves as an exit node for VM-B's forwarded traffic.
# Default: false
EXIT_NODE_ENABLED=false

# Tunnel type for the exit-node tunnel: wireguard, ssh, tailscale, or xray.
# Required when EXIT_NODE_ENABLED=true.
# EXIT_NODE_TUNNEL_TYPE=wireguard

# IP address or hostname of the peer VM that forwards traffic to this exit node.
# Accepts both IP addresses (e.g., 203.0.113.10) and hostnames (e.g., entrance.example.com).
# Required when EXIT_NODE_ENABLED=true.
# EXIT_NODE_PEER_HOST=203.0.113.10

# Tunnel subnet for the exit-node tunnel (must differ from TUNNEL_SUBNET
# if both forwarding and exit-node role are enabled on the same VM).
# Default: 10.99.1.0/30
# EXIT_NODE_TUNNEL_SUBNET=10.99.1.0/30

# WireGuard listen port for the exit-node tunnel.
# Must differ from the main AWG port and the forwarding tunnel port.
# Default: 51822
# EXIT_NODE_LISTEN_PORT=51822

# Set to true if the peer VM initiates the tunnel connection to this exit node.
# Default: false
# EXIT_NODE_REVERSE_INITIATED=false

# ============================================================================
# INITIAL CLIENTS
# ============================================================================

# Name for the initial Xray VLESS+Reality client created during deployment.
# A UUID and VLESS share link are generated automatically.
# Default: default-client
XRAY_INITIAL_CLIENT=default-client

# Name for the initial AmneziaWG peer created during deployment.
# WireGuard keys and a .conf file are generated automatically.
# Default: default-peer
AWG_INITIAL_PEER=default-peer

# ============================================================================
# OUTPUT
# ============================================================================

# Directory where all generated configs, scripts, and docs are written.
# Default: ./deploy
OUTPUT_DIR=./deploy

# Path to the deployment log file (records all actions at DEBUG level).
# Default: ./deploy/deploy.log
DEPLOYMENT_LOG_PATH=./deploy/deploy.log
